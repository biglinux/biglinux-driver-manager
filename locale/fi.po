#: usr/share/big-driver-manager/ui/mesa_page.py:196
msgid "Choose which Mesa build to use. Only one variant can be active at a time."
msgstr "Valitse käytettävä Mesa-versio. Vain yksi versio voi olla aktiivinen kerrallaan."
# 
# File: big-driver-manager/usr/share/big-driver-manager/ui/mesa_page.py, line: 209
#: usr/share/big-driver-manager/ui/mesa_page.py:209
msgid ""
"<b>Note:</b> You are using the NVIDIA proprietary driver. Mesa is only used for minor tasks in this "
"case. We recommend keeping the <b>Stable</b> variant — other versions will not improve performance "
"and may cause instabilities."
msgstr ""
