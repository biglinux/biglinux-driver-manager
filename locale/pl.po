#: usr/share/big-driver-manager/ui/mesa_data.py:179
msgid "VAAPI for AMD and NVIDIA open-source (Nouveau)"
msgstr "VAAPI dla AMD i NVIDIA typu open source (Nouveau)"
# 
# File: big-driver-manager/usr/share/big-driver-manager/ui/mesa_data.py, line: 186
#: usr/share/big-driver-manager/ui/mesa_data.py:186
msgid ""
"VDPAU for AMD/NVIDIA open-source — legacy API being replaced by VAAPI and Vulkan. Probably not "
"needed."
msgstr ""
"VDPAU dla oprogramowania typu open source AMD/NVIDIA — starsze API zostaje zastąpione przez VAAPI i "
"Vulkan. Prawdopodobnie nie potrzebne."
# 
# File: big-driver-manager/usr/share/big-driver-manager/ui/mesa_data.py, line: 197
#: usr/share/big-driver-manager/ui/mesa_data.py:197
