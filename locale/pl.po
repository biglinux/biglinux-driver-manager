# 
# File: big-driver-manager/usr/share/big-driver-manager/ui/mesa_data.py, line: 149
#: usr/share/big-driver-manager/ui/mesa_data.py:149
msgid "Video Playback"
msgstr ""
"Dekodowanie wideo z akceleracją sprzętową (VAAPI/VDPAU). Sprawia, że ​​filmy, przesyłanie "
"strumieniowe i rozmowy wideo są płynniejsze, jednocześnie zmniejszając zużycie procesora i energii."
# 
# File: big-driver-manager/usr/share/big-driver-manager/ui/mesa_data.py, line: 152
#: usr/share/big-driver-manager/ui/mesa_data.py:152
msgid ""
"Hardware-accelerated video decoding (VAAPI/VDPAU). Makes videos, streaming and video calls smoother "
"while reducing CPU and power usage."
msgstr ""
"Dekodowanie wideo z akceleracją sprzętową (VAAPI/VDPAU). Sprawia, że ​​filmy, przesyłanie "
"strumieniowe i rozmowy wideo są płynniejsze, jednocześnie zmniejszając zużycie procesora i energii."
# 
# File: big-driver-manager/usr/share/big-driver-manager/ui/mesa_data.py, line: 159
#: usr/share/big-driver-manager/ui/mesa_data.py:159
msgid "VAAPI for NVIDIA proprietary driver"
msgstr "VAAPI dla zastrzeżonego sterownika NVIDIA"
# 
