# 
# File: big-driver-manager/usr/share/big-driver-manager/ui/mesa_data.py, line: 281
#: usr/share/big-driver-manager/ui/mesa_data.py:290
msgid ""
"Modified version with gaming optimizations for extra performance. Reliable for most users but may "
"rarely cause instabilities."
msgstr ""
"Zmodyfikowana wersja z optymalizacjami gier dla dodatkowej wydajności. Niezawodny dla większości "
"użytkowników, ale rzadko może powodować niestabilność."
# 
