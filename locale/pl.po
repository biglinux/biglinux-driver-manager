# 
# File: big-driver-manager/usr/share/big-driver-manager/ui/mesa_page.py, line: 127
#: usr/share/big-driver-manager/ui/mesa_page.py:129
msgid ""
"On Linux, video drivers for AMD, Intel and NVIDIA (free software Nouveau) are built into a single "
"project called <b>Mesa</b>. Below you can choose a Mesa variant and manage extra packages for "
"gaming, video playback, compute and AI."
msgstr ""
"W systemie Linux sterowniki wideo dla AMD, Intel i NVIDIA (bezpłatne oprogramowanie Nouveau) są "
"wbudowane w jeden projekt o nazwie <b>Mesa</b>. Poniżej możesz wybrać wariant Mesa i zarządzać "
"dodatkowymi pakietami do gier, odtwarzania wideo, obliczeń i sztucznej inteligencji."
# 
# File: big-driver-manager/usr/share/big-driver-manager/ui/mesa_page.py, line: 150
#: usr/share/big-driver-manager/ui/mesa_page.py:152
msgid ""
"Your computer has an <b>NVIDIA</b> graphics card. You can install the official proprietary driver "
"for the best performance in gaming, AI and professional applications."
msgstr ""
"Twój komputer jest wyposażony w kartę graficzną <b>NVIDIA</b>. Możesz zainstalować oficjalny, "
"zastrzeżony sterownik, aby uzyskać najlepszą wydajność w grach, sztucznej inteligencji i "
"aplikacjach profesjonalnych."
# 
# File: big-driver-manager/usr/share/big-driver-manager/ui/mesa_page.py, line: 183
#: usr/share/big-driver-manager/ui/mesa_page.py:185
msgid "Mesa Variant"
msgstr "Wariant Mesa"
# 
# File: big-driver-manager/usr/share/big-driver-manager/ui/mesa_page.py, line: 194
#: usr/share/big-driver-manager/ui/mesa_page.py:196
msgid "Choose which Mesa build to use. Only one variant can be active at a time."
msgstr "Wybierz wersję Mesy, której chcesz użyć. W danym momencie aktywny może być tylko jeden wariant."
# 
# File: big-driver-manager/usr/share/big-driver-manager/ui/mesa_page.py, line: 209
#: usr/share/big-driver-manager/ui/mesa_page.py:209
msgid ""
"<b>Note:</b> You are using the NVIDIA proprietary driver. Mesa is only used for minor tasks in this "
"case. We recommend keeping the <b>Stable</b> variant — other versions will not improve performance "
"and may cause instabilities."
msgstr ""
