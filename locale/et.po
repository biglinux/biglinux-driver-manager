# File: big-driver-manager/usr/share/big-driver-manager/ui/mesa_data.py, line:
# 200
#: /home/talesam/Servidor/GitHub/biglinux-driver-manager/usr/share/big-driver-manager/ui/mesa_data.py:200
msgid ""
"Your graphics card can do more than display images — it can also help with "
"heavy processing tasks. These libraries allow programs to use the GPU for "
"things like artificial intelligence, video editing, 3D rendering, image "
"processing and scientific simulations. Examples: running local AI assistants"
" (Ollama, LocalAI), transcribing audio with Whisper, rendering 3D scenes in "
"Blender, applying filters in GIMP or Darktable, generating images with "
"Stable Diffusion, and running physics simulations."
msgstr ""
"Teie graafikakaart suudab teha rohkem kui ainult pilte kuvada — see võib "
"aidata ka raskete töötlemistöötlemistega. Need teegid võimaldavad "
"programmidel kasutada GPU-d selliste ülesannete jaoks nagu tehisintellekt, "
"video redigeerimine, 3D renderdamine, pilditöötlus ja teaduslikud "
"simulatsioonid. Näited: kohalike AI assistentide käitamine (Ollama, "
"LocalAI), heli transkribeerimine Whisperiga, 3D stseenide renderdamine "
"Blenderis, filtrite rakendamine GIMPis või Darktable'is, piltide "
"genereerimine Stable Diffusioniga ja füüsikasimulatsioonide käitamine."

