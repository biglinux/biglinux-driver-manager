# File: big-driver-manager/usr/share/big-driver-manager/ui/mesa_page.py, line: 127
#: usr/share/big-driver-manager/ui/mesa_page.py:129
msgid ""
"On Linux, video drivers for AMD, Intel and NVIDIA (free software Nouveau) are built into a single "
"project called <b>Mesa</b>. Below you can choose a Mesa variant and manage extra packages for "
"gaming, video playback, compute and AI."
msgstr ""
"Sous Linux, les pilotes vidéo pour AMD, Intel et NVIDIA (logiciel gratuit Nouveau) sont intégrés "
"dans un seul projet appelé <b>Mesa</b>. Ci-dessous, vous pouvez choisir une variante Mesa et gérer "
"des packages supplémentaires pour les jeux, la lecture vidéo, le calcul et l'IA."
# 
# File: big-driver-manager/usr/share/big-driver-manager/ui/mesa_page.py, line: 150
#: usr/share/big-driver-manager/ui/mesa_page.py:152
msgid ""
"Your computer has an <b>NVIDIA</b> graphics card. You can install the official proprietary driver "
"for the best performance in gaming, AI and professional applications."
msgstr ""
"Votre ordinateur est équipé d'une carte graphique <b>NVIDIA</b>. Vous pouvez installer le pilote "
"propriétaire officiel pour obtenir les meilleures performances dans les jeux, l'IA et les "
"applications professionnelles."
# 
# File: big-driver-manager/usr/share/big-driver-manager/ui/mesa_page.py, line: 183
#: usr/share/big-driver-manager/ui/mesa_page.py:185
