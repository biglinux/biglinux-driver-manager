#!/bin/bash
# Wrapper to execute Big Driver Manager GUI

# Detect the installation directory
# Search first in Python site-packages (newest to oldest version)
# Then fallback to /usr/share/big-driver-manager or local directory
for i in /usr/lib/python3.{25..6}/site-packages/big-driver-manager /usr/share/big-driver-manager; do
    if [[ -e "$i" ]]; then
        BIG_DRIVER_MANAGER_DIR="$i"
        break
    fi
done

# If not found, try the local directory (development)
if [[ -z "$BIG_DRIVER_MANAGER_DIR" ]]; then
    SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
    BIG_DRIVER_MANAGER_DIR="$SCRIPT_DIR/../share/big-driver-manager"
fi

# Execute main.py
exec python3 "$BIG_DRIVER_MANAGER_DIR/main.py" "$@"
